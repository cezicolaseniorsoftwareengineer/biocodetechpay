# Configurações da aplicação
APP_NAME=Fintech Tech Challenge
VERSION=1.0.0
DEBUG=False

# Database
DATABASE_URL=sqlite:///./fintech.db

# Security (TROCAR EM PRODUÇÃO)
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Logging
LOG_LEVEL=INFO

# Asaas Payment Gateway Integration
# CRITICAL: NEVER commit .env file with real API key to Git
# Get your API key at: https://www.asaas.com/config/api
# Production key format: $aact_prod_...
# Sandbox key format: $aact_sandbox_...
ASAAS_API_KEY=your-asaas-api-key-here
ASAAS_USE_SANDBOX=true
